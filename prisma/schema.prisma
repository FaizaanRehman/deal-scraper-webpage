generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InstagramMediaType {
  IMAGE
  VIDEO
  CAROUSEL
}

model Deal {
  id         Int      @id @default(autoincrement())
  owner      String   @default("unknown")
  caption    String
  title      String?
  url        String   @unique
  imageUrl   String   @default("") // thumbnail / preview imageUrl
  mediaType  InstagramMediaType @default(IMAGE)
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}